        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Active HTTP Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "contextpilot_http_active_requests",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "contextpilot-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
