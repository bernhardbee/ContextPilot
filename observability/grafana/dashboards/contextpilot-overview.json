      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "title": "AI Requests by Provider",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (provider) (rate(contextpilot_ai_requests_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "contextpilot-prometheus"
      },
      "fieldConfig": {
