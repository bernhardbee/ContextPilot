        "x": 12,
        "y": 16
      },
      "id": 6,
      "title": "AI Error Ratio",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(contextpilot_ai_requests_total{status=~\"client_error|server_error\"}[5m])) / clamp_min(sum(rate(contextpilot_ai_requests_total[5m])), 0.001)",
          "refId": "A"
