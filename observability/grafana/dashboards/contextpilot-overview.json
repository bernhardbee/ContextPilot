      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(contextpilot_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "contextpilot-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "5xx Error Ratio",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(contextpilot_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(contextpilot_http_requests_total[5m])), 0.001)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "contextpilot-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
